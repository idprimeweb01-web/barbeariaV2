# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o .env — ele já está no .gitignore.

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/barberos

# ── Segurança (Flask / JWT) ───────────────────────────────────────────────────
# Gere as duas chaves abaixo com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NUNCA use um placeholder aqui — app/__init__.py recusa iniciar se detectar
# uma chave curta, com baixa entropia, ou contendo trechos como "changeme",
# "your-secret-key", "substitua" etc.
SECRET_KEY=gere-uma-chave-real-de-32-bytes-com-o-comando-acima
JWT_SECRET_KEY=gere-outra-chave-real-de-32-bytes-com-o-comando-acima

# ── Ambiente ──────────────────────────────────────────────────────────────────
# "production" liga cookies Secure/SameSite estritos — use em qualquer
# ambiente acessível pela internet (inclusive staging). Só use "development"
# em localhost.
FLASK_ENV=development

# ── Cloudinary (upload de imagens: comprovantes PIX, fotos de produto,
# customização visual da barbearia) ───────────────────────────────────────────
# Painel: https://cloudinary.com/console (Settings → Access Keys)
CLOUDINARY_CLOUD_NAME=seu-cloud-name-aqui
CLOUDINARY_API_KEY=sua-api-key-aqui
CLOUDINARY_API_SECRET=seu-api-secret-aqui

# ── Rate limiting (Script 13/Bloco 4.2) ───────────────────────────────────────
# Em produção com mais de 1 worker gunicorn, usar Redis (memory:// é
# por-worker — ver DT-006 / RELATORIO_BLOCO_13.txt).
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=300 per minute
# RL_LOGIN, RL_CADASTRO, RL_AGENDAR, RL_PLANO_SOLICITAR, RL_COMPROVANTE,
# RL_CUPOM_VALIDAR, RL_SLOTS têm defaults sensatos no código — só defina
# aqui se precisar sobrescrever algum.

# ── Seed de administrador (rodar `python seeds_prod.py` em produção,
# NUNCA os scripts de seed de dev) ────────────────────────────────────────────
ADMIN_EMAIL=admin@seudominio.com
ADMIN_SENHA=defina-uma-senha-forte-so-para-o-primeiro-acesso

# ── Opcional: desliga o scheduler de lembretes (usado em testes) ─────────────
# DISABLE_SCHEDULER=1
